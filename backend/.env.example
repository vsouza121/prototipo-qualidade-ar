# ===================================
# Configurações do Servidor
# ===================================
NODE_ENV=development
PORT=3000

# ===================================
# Banco de Dados SQL Server
# ===================================
DB_HOST=localhost
DB_PORT=1433
DB_NAME=qualidade_ar

# OPÇÃO 1: Autenticação SQL (com usuário e senha)
DB_USER=sa
DB_PASSWORD=SuaSenhaAqui123!
DB_WINDOWS_AUTH=false

# OPÇÃO 2: Autenticação Windows (sem usuário/senha)
# Descomente as linhas abaixo e comente as de cima
# DB_USER=
# DB_PASSWORD=
# DB_WINDOWS_AUTH=true
# DB_DOMAIN=           (opcional - domínio Windows)

# ===================================
# JWT - Autenticação
# ===================================
JWT_SECRET=seu_segredo_jwt_super_secreto_aqui_2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=seu_segredo_refresh_token_aqui_2026
JWT_REFRESH_EXPIRES_IN=7d

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# CORS - Origens permitidas
# ===================================
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# ===================================
# Email (para alertas)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app

# ===================================
# API Gemini (Assistente IA)
# ===================================
GEMINI_API_KEY=
